# ============================================================
# CoolTrack Pro - variaveis de ambiente
# ============================================================
# Copie este arquivo para .env.local em desenvolvimento ou configure as
# variaveis no painel do Cloudflare Pages.
#
# NUNCA commite .env.local, .env.production ou chaves reais no git.
# ============================================================

# ------ Supabase ------------------------------------------------

# URL do projeto Supabase.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Chave anon/publica do Supabase.
# Use apenas a chave "anon". Nunca use service_role no frontend.
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# ------ Auth redirect ------------------------------------------

# URL para onde o Supabase redireciona apos login OAuth e recuperacao de senha.
# Producao atual:
#   https://cool-track-pro.pages.dev/
# Desenvolvimento:
#   http://localhost:5173/
#
# Configure tambem em:
#   Supabase Dashboard -> Authentication -> URL Configuration
#   Site URL e Redirect URLs
VITE_AUTH_REDIRECT_URL=https://cool-track-pro.pages.dev/

# ------ EmailJS - feedback opcional -----------------------------

# Quando configurado, o envio de feedback tambem dispara email.
# Se vazio/incorreto, o app segue funcionando e apenas ignora o email.
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx

# ------ Sentry - observabilidade opcional -----------------------

# Quando configurado, erros capturados por handleError() sao enviados ao Sentry.
# Se vazio, a camada de observabilidade vira no-op.
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=
VITE_APP_VERSION=

# ============================================================
# Checklist antes do deploy
# ============================================================
# [ ] VITE_AUTH_REDIRECT_URL aponta para https://cool-track-pro.pages.dev/
# [ ] VITE_SUPABASE_ANON_KEY e a chave anon/publica, nao service_role
# [ ] Variaveis configuradas no Cloudflare Pages
# [ ] Supabase real, storage, PDF/share, assinatura, PMOC e billing so entram
#     novamente por etapas proprias futuras
# ============================================================
