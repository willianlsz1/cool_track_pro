node_modules/
/moon-bridge/
# Saidas do Vite - a unica "verdadeira" e `dist/`. Qualquer outra pasta
# `dist-<qualquer-coisa>/` e artefato de build ou verificacao local e
# nunca deve ser commitada.
dist/
dist-*/
# `dist.stale.<timestamp>` e usado como escape hatch quando um sandbox
# nao consegue executar `rm` na pasta dist/ - o build e renomeado em
# vez de apagado. Nunca deve ser commitado.
dist.stale.*/
dist.stale.*
coverage/
test-results/
.eslintcache
.prettiercache
.env
.env.local
.env.production
.env.staging
.DS_Store
*.log
*.key
*.pem
*.cert
*.p12

# Arquivos temporarios de desenvolvimento / preview
*-preview.html
pdf_validacao.pdf

# Artefatos temporarios do Vite (gerados em dev, nunca commitados)
vite.config.js.timestamp-*

# Credenciais Android (keystore - NUNCA commitar)
*.keystore
*.jks

# Supabase CLI - estado local, nao pra versionar
supabase/.temp/

# IDE / editor
.idea/
.vscode/
*.iml

# OS
Thumbs.db
.claude/settings.local.json
# Worktrees locais do Claude Code (nao versionar)
.claude/worktrees/
